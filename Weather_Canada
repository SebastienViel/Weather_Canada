/**
 * Tomorrow's Max Temperature Driver
 * Uses OpenWeatherMap One Call API 3.0
 * Author: Sébastien Viel
 * Version: 1.0.0
 */

metadata {
    definition(name: "Tomorrow Max Temp", namespace: "SebastienViel", author: "Sébastien Viel") {
        capability "Refresh"
        capability "Sensor"
        
        attribute "tomorrowMaxTemp", "number"
        attribute "tomorrowMaxTempF", "number"
        attribute "lastUpdated", "string"
        attribute "forecastDate", "string"
    }

    preferences {
        input name: "apiKey",    type: "text",   title: "OWM API Key",   required: true
        input name: "latitude",  type: "text",   title: "Latitude",      required: true, defaultValue: "46.5"
        input name: "longitude", type: "text",   title: "Longitude",     required: true, defaultValue: "-66.5"
        input name: "units",     type: "enum",   title: "Units",         options: ["metric","imperial"], defaultValue: "metric"
        input name: "pollHours", type: "number", title: "Refresh every N hours", defaultValue: 1
        input name: "logEnable", type: "bool",   title: "Enable debug logging", defaultValue: false
    }
}

def installed() {
    log.info "Tomorrow Max Temp driver installed"
    initialize()
}

def updated() {
    log.info "Tomorrow Max Temp driver updated"
    unschedule()
    initialize()
}

def initialize() {
    if (pollHours) {
        def cronExpr = "0 0 */${pollHours} * * ?"
        schedule(cronExpr, refresh)
    }
    refresh()
}

def refresh() {
    if (!apiKey || !latitude || !longitude) {
        log.error "Missing API key or coordinates"
        return
    }

    def url = "https://api.openweathermap.org/data/3.0/onecall" +
              "?lat=${latitude}&lon=${longitude}" +
              "&exclude=current,minutely,hourly,alerts" +
              "&units=${units ?: 'metric'}" +
              "&appid=${apiKey}"

    if (logEnable) log.debug "Fetching: ${url}"

    def params = [uri: url, contentType: "application/json"]

    asynchttpGet("handleResponse", params)
}

def handleResponse(response, data) {
    if (response.hasError()) {
        log.error "OWM API error: ${response.getErrorMessage()}"
        return
    }

    try {
        def json = response.json
        def tomorrow = json.daily[1]  // index 0 = today, 1 = tomorrow

        def maxC = tomorrow.temp.max as BigDecimal
        def maxF = (maxC * 9 / 5 + 32).setScale(1, BigDecimal.ROUND_HALF_UP)

        // Forecast date (Unix timestamp → date string)
        def forecastDate = new Date(tomorrow.dt * 1000L).format("yyyy-MM-dd", location.timeZone)

        sendEvent(name: "tomorrowMaxTemp",  value: maxC.setScale(1, BigDecimal.ROUND_HALF_UP),
                  unit: units == "imperial" ? "°F" : "°C")
        sendEvent(name: "tomorrowMaxTempF", value: maxF, unit: "°F")
        sendEvent(name: "forecastDate",     value: forecastDate)
        sendEvent(name: "lastUpdated",      value: new Date().format("yyyy-MM-dd HH:mm:ss", location.timeZone))

        if (logEnable) log.debug "Tomorrow max: ${maxC}°C / ${maxF}°F for ${forecastDate}"

    } catch (e) {
        log.error "Failed to parse OWM response: ${e}"
    }
}
